{
  "name": "dixipro/magicpro",
  "description": "Magic application inside Laravel",
  "type": "laravel-package",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0 || ^13.0",
    "livewire/livewire": "^3.6",
    "aws/aws-sdk-php": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "MagicProSrc\\": "src/",
      "MagicProDatabaseModels\\": "database/Models/",
      "MagicProAdminControllers\\": "admin/controller/",
      "MagicProAdminMiddleware\\": "admin/middleware/",
      "MagicProControllers\\": "../../../storage/dataMagicPro/controller/",
      "MagicProDatabase\\": "database"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "MagicProSrc\\MagicServiceProvider"
      ]
    },
    "uploadComposerCommand": "Run in project root: composer update dixipro/magicpro or composer dump-autoload"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
